{
  "name": "reacttypingspeedtest",
  "version": "1.0.0",
  "description": "Приложение для теста скорости печати",
  "private": true,
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "dev": "run-p dev:frontend dev:server",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:server": "npm run dev --workspace server",
    "docker": "docker compose up --build",
    "start": "run-p dev docker"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
